// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ProjectPlatform {
  github
  gitlab
  local
}

enum ProjectStatus {
  active
  paused
  archived
}

enum MilestoneStatus {
  on_track
  at_risk
  delayed
  done
}

enum NoteTemplate {
  feature
  performance
  incident
  prove_of_concept
}

enum NoteImpact {
  critical
  high
  medium
  low
}

enum NoteState {
  draft
  development
  in_review
  deployed
  monitoring
  rolled_back
}

enum RunStatus {
  queued
  running
  success
  failed
  cancelled
}

enum AgentRunStatus {
  running
  success
  failed
  skipped
}

enum LlmCallStatus {
  success
  failed
  timeout
  warning
}

enum FileChangeOperation {
  create
  update
  delete
}

model Project {
  id           String          @id
  name         String          @unique
  description  String
  platform     ProjectPlatform
  org          String
  status       ProjectStatus   @default(active)
  openIssues   Int             @default(0)
  closedIssues Int             @default(0)
  stars        Int             @default(0)
  branches     Int             @default(0)
  milestones   Milestone[]
  notes        Note[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
}

model Milestone {
  id        String          @id
  projectId String
  title     String
  dueDate   DateTime        @db.Date
  progress  Int             @default(0)
  status    MilestoneStatus
  project   Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  noteLinks NoteMilestone[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([projectId])
  @@index([status])
}

model SkillCategory {
  id        String   @id @default(cuid())
  name      String   @unique
  skills    Skill[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Skill {
  id            String        @id @default(cuid())
  categoryId    String
  name          String        @unique
  category      SkillCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  proficiencies Proficiency[]
  noteLinks     NoteSkill[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([categoryId])
}

model Proficiency {
  id        String   @id @default(cuid())
  skillId   String
  level     Int
  skill     Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([skillId])
}

model Note {
  id             String              @id
  projectId      String?
  project        Project?            @relation(fields: [projectId], references: [id], onDelete: SetNull)
  template       NoteTemplate
  impact         NoteImpact
  state          NoteState
  title          String
  date           DateTime            @db.Date
  research       String              @default("")
  summaryBullets NoteSummaryBullet[]
  fields         NoteField[]
  metrics        NoteMetric?
  skills         NoteSkill[]
  milestones     NoteMilestone[]
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([projectId])
  @@index([date])
  @@index([template])
  @@index([impact])
  @@index([state])
}

model NoteSummaryBullet {
  id       String @id @default(cuid())
  noteId   String
  position Int
  text     String
  note     Note   @relation(fields: [noteId], references: [id], onDelete: Cascade)

  @@unique([noteId, position])
  @@index([noteId])
}

model NoteField {
  id     String @id @default(cuid())
  noteId String
  key    String
  value  String
  note   Note   @relation(fields: [noteId], references: [id], onDelete: Cascade)

  @@unique([noteId, key])
  @@index([noteId])
}

model NoteMetric {
  noteId      String @id
  baselineMs  Int?
  postMs      Int?
  coveragePct Int?
  note        Note   @relation(fields: [noteId], references: [id], onDelete: Cascade)
}

model NoteSkill {
  noteId  String
  skillId String
  note    Note   @relation(fields: [noteId], references: [id], onDelete: Cascade)
  skill   Skill  @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([noteId, skillId])
  @@index([skillId])
}

model NoteMilestone {
  noteId      String
  milestoneId String
  note        Note      @relation(fields: [noteId], references: [id], onDelete: Cascade)
  milestone   Milestone @relation(fields: [milestoneId], references: [id], onDelete: Cascade)

  @@id([noteId, milestoneId])
  @@index([milestoneId])
}

model VelocityPoint {
  id        String   @id @default(cuid())
  week      String   @unique
  planned   Int
  completed Int
  createdAt DateTime @default(now())
}

model FocusAllocationPoint {
  id        String   @id @default(cuid())
  name      String   @unique
  value     Int
  createdAt DateTime @default(now())
}

model IssueResolutionPoint {
  id        String   @id @default(cuid())
  week      String   @unique
  avgHours  Int
  createdAt DateTime @default(now())
}

model SkillRadarPoint {
  id        String   @id @default(cuid())
  skill     String   @unique
  q1        Int
  q2        Int
  createdAt DateTime @default(now())
}

model CommitActivityPoint {
  id        String   @id @default(cuid())
  day       String   @unique
  commits   Int
  createdAt DateTime @default(now())
}

model PerformanceTrendPoint {
  id        String   @id @default(cuid())
  week      String   @unique
  p99       Int
  coverage  Int
  createdAt DateTime @default(now())
}

model CeoReportSnapshot {
  id           String    @id @default(cuid())
  documentName String
  language     String?
  surveyedAt   DateTime?
  surveyedBy   String?
  purpose      String?
  payload      Json
  createdAt    DateTime  @default(now())
}

model Session {
  id             String            @id @default(cuid())
  runId          String            @unique
  status         RunStatus         @default(queued)
  sourceDir      String?
  targetDir      String?
  modulePath     String?
  targetPattern  String?
  compilePassed  Boolean?
  testsPassed    Boolean?
  fixIterations  Int               @default(0)
  durationMs     Int?
  totalCostUsd   Decimal?          @db.Decimal(12, 6)
  artifactPrefix String?
  startedAt      DateTime?
  endedAt        DateTime?
  handoffs       Handoff[]
  history        History[]
  logs           LogAudit[]
  agentRuns      AgentRun[]
  llmCalls       LlmCall[]
  fileChanges    FileChange[]
  artifacts      Artifact[]
  metadata       SessionMetadata[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([status])
  @@index([startedAt])
}

model Handoff {
  id        String   @id @default(cuid())
  sessionId String
  fromAgent String
  toAgent   String
  payload   Json?
  createdAt DateTime @default(now())
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

model History {
  id        String   @id @default(cuid())
  sessionId String
  eventType String
  payload   Json?
  createdAt DateTime @default(now())
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([eventType])
}

model LogAudit {
  id        String   @id @default(cuid())
  sessionId String?
  level     String
  message   String
  context   Json?
  createdAt DateTime @default(now())
  session   Session? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([sessionId])
  @@index([level])
}

model AgentRun {
  id           String         @id @default(cuid())
  sessionId    String
  agentName    String
  fixIteration Int            @default(0)
  status       AgentRunStatus
  durationMs   Int?
  model        String?
  provider     String?
  tokensIn     Int?
  tokensOut    Int?
  totalTokens  Int?
  costUsd      Decimal?       @db.Decimal(12, 6)
  langfuseUrl  String?
  startedAt    DateTime?
  endedAt      DateTime?
  session      Session        @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  llmCalls     LlmCall[]
  fileChanges  FileChange[]
  createdAt    DateTime       @default(now())

  @@index([sessionId])
  @@index([agentName])
  @@index([status])
}

model LlmCall {
  id           String        @id @default(cuid())
  sessionId    String
  agentRunId   String?
  provider     String?
  model        String?
  status       LlmCallStatus @default(success)
  systemPrompt String?
  userPrompt   String?
  response     String?
  errorMessage String?
  tokensIn     Int?
  tokensOut    Int?
  totalTokens  Int?
  costUsd      Decimal?      @db.Decimal(12, 6)
  latencyMs    Int?
  calledAt     DateTime      @default(now())
  session      Session       @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  agentRun     AgentRun?     @relation(fields: [agentRunId], references: [id], onDelete: SetNull)

  @@index([sessionId])
  @@index([agentRunId])
  @@index([status])
  @@index([calledAt])
}

model FileChange {
  id           String              @id @default(cuid())
  sessionId    String
  agentRunId   String?
  filePath     String
  operation    FileChangeOperation
  linesAdded   Int                 @default(0)
  linesDeleted Int                 @default(0)
  diff         String?
  createdAt    DateTime            @default(now())
  session      Session             @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  agentRun     AgentRun?           @relation(fields: [agentRunId], references: [id], onDelete: SetNull)

  @@index([sessionId])
  @@index([agentRunId])
}

model Artifact {
  id        String   @id @default(cuid())
  sessionId String
  key       String
  url       String?
  mimeType  String?
  sizeBytes Int?
  createdAt DateTime @default(now())
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, key])
  @@index([sessionId])
}

model SessionMetadata {
  id        String   @id @default(cuid())
  sessionId String
  key       String
  value     String
  createdAt DateTime @default(now())
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, key])
  @@index([sessionId])
}
